{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orunla",
  "version": "0.4.1",
  "identifier": "com.orunla.memory",
  "build": {
    "frontendDist": "../ui",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Orunla Memory",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/onnxruntime.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}